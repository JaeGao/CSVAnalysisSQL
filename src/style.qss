/* style.qss - Clean, Basic Light Theme */

QMainWindow {
    background-color: #F8F9FA;
}

/* Splitter Handles */
QSplitter::handle {
    background-color: transparent;
}

QSplitter::handle:hover {
    background-color: #E9ECEF;
}

QSplitter::handle:pressed {
    background-color: #DEE2E6;
}

QSplitter::handle:horizontal {
    width: 6px;
    image: url(grip_horizontal.png);
    border-left: 1px solid #DEE2E6;
}

QSplitter::handle:vertical {
    height: 6px;
    image: url(grip_vertical.png);
    border-top: 1px solid #DEE2E6;
}

QWidget {
    font-family: 'Segoe UI', 'San Francisco', 'Inter', sans-serif;
    color: #212529; /* Dark gray/almost black for maximum readability */
    font-size: 14px;
}

/* Scroll Area fixes to ensure legibility */
QScrollArea {
    background-color: #FFFFFF;
    border: 1px solid #CED4DA;
}
QScrollArea > QWidget > QWidget {
    background-color: #FFFFFF;
}

/* Sidebar Styling */
#sidebar {
    background-color: #F8F9FA;
    border-right: 1px solid #DEE2E6;
    padding: 10px;
}

/* GroupBox Styling */
QGroupBox {
    border: 1px solid #CED4DA;
    border-radius: 4px;
    margin-top: 15px;
    background-color: #FFFFFF;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 5px;
    color: #495057;
    font-weight: bold;
    margin-top: -10px;
    background-color: #FFFFFF;
}

/* Buttons */
QPushButton {
    background-color: #E9ECEF;
    color: #212529;
    border: 1px solid #CED4DA;
    border-radius: 4px;
    padding: 6px 16px;
    min-height: 18px;
}

QPushButton:hover {
    background-color: #DEE2E6;
    border: 1px solid #ADB5BD;
}

QPushButton:pressed {
    background-color: #CED4DA;
    border: 1px solid #868E96;
}

QPushButton:disabled {
    background-color: #F8F9FA;
    color: #ADB5BD;
    border: 1px solid #DEE2E6;
}

QPushButton#executeBtn {
    background-color: #0D6EFD; /* Primary blue */
    color: #FFFFFF;
    font-weight: bold;
    border: none;
}

QPushButton#executeBtn:hover {
    background-color: #0B5ED7;
}

QPushButton#executeBtn:pressed {
    background-color: #0A58CA;
}

QPushButton#presetBtn {
    background-color: #FFC107; /* Warning yellow/orange */
    color: #000000;
    font-weight: bold;
    border: none;
}

QPushButton#presetBtn:hover {
    background-color: #FFCA2C;
}

QPushButton#exportBtn {
    background-color: #198754; /* Success green */
    color: #FFFFFF;
    font-weight: bold;
    border: none;
}

QPushButton#exportBtn:hover {
    background-color: #157347;
}

/* Comboboxes, LineEdits, DateEdits, TextEdits, Lists, Trees */
QComboBox, QLineEdit, QDateEdit, QPlainTextEdit, QListWidget, QTreeWidget {
    background-color: #FFFFFF;
    border: 1px solid #CED4DA;
    border-radius: 4px;
    padding: 4px;
    color: #212529;
}

QComboBox:hover, QLineEdit:hover, QDateEdit:hover, QPlainTextEdit:hover, QListWidget:hover, QTreeWidget:hover {
    border: 1px solid #86B7FE;
}

QComboBox::drop-down {
    border: none;
    width: 20px;
}

QComboBox QAbstractItemView, QListWidget::item:selected, QTreeWidget::item:selected, QTableView::item:selected {
    background-color: #0D6EFD;
    color: #FFFFFF;
}

QListWidget::item:selected:!active, QTreeWidget::item:selected:!active, QTableView::item:selected:!active {
    background-color: #6C757D;
    color: #FFFFFF;
}

QListWidget, QTreeWidget, QTableView {
    outline: none;
}

/* Table View */
QTableView {
    background-color: #FFFFFF;
    alternate-background-color: #F8F9FA;
    gridline-color: #DEE2E6;
    border: 1px solid #DEE2E6;
    selection-background-color: #0D6EFD;
    selection-color: #FFFFFF;
    color: #212529;
}

QHeaderView::section {
    background-color: #F8F9FA;
    color: #495057;
    padding: 6px;
    border: none;
    border-right: 1px solid #DEE2E6;
    border-bottom: 1px solid #DEE2E6;
    font-weight: bold;
}

/* Checkboxes */
QCheckBox {
    color: #212529;
    spacing: 5px;
}

/* Labels */
QLabel {
    background-color: transparent;
    border: none;
    padding: 0px;
}

/* Scrollbars - Vertical */
QScrollBar:vertical {
    border: none;
    background-color: #F8F9FA;
    width: 10px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background-color: #CED4DA;
    min-height: 30px;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background-color: #ADB5BD;
}

QScrollBar::handle:vertical:pressed {
    background-color: #868E96;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
    border: none;
    background: none;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

/* Menu Bar */
QMenuBar {
    background-color: #F8F9FA;
    border-bottom: 1px solid #DEE2E6;
    padding: 2px 4px;
}

QMenuBar::item {
    background-color: transparent;
    padding: 4px 10px;
    border-radius: 3px;
}

QMenuBar::item:selected {
    background-color: #E9ECEF;
}

QMenu {
    background-color: #FFFFFF;
    border: 1px solid #CED4DA;
    border-radius: 4px;
    padding: 4px 0px;
}

QMenu::item {
    padding: 5px 24px 5px 16px;
}

QMenu::item:selected {
    background-color: #0D6EFD;
    color: #FFFFFF;
}

QMenu::separator {
    height: 1px;
    background-color: #DEE2E6;
    margin: 3px 8px;
}

/* Tab Widget */
QTabWidget::pane {
    border: 1px solid #DEE2E6;
    border-top: none;
    background-color: #F8F9FA;
}

QTabBar::tab {
    background-color: #E9ECEF;
    color: #495057;
    border: 1px solid #DEE2E6;
    border-bottom: none;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    /* right padding leaves breathing room next to the × close button */
    padding: 5px 6px 5px 12px;
    margin-right: 2px;
    min-width: 80px;
}

QTabBar::tab:selected {
    background-color: #F8F9FA;
    color: #212529;
    font-weight: bold;
    border-bottom: 1px solid #F8F9FA;
}

QTabBar::tab:hover:!selected {
    background-color: #DEE2E6;
}

/* "+" tab is always last */
QTabBar::tab:last {
    min-width: 32px;
    padding: 5px 10px;
    color: #6C757D;
    font-weight: bold;
    font-size: 15px;
    background-color: transparent;
    border-color: transparent;
}

QTabBar::tab:last:hover {
    background-color: #DEE2E6;
    border-color: #DEE2E6;
    color: #212529;
}

/* Custom × close button on each real tab */
QPushButton#tabCloseBtn {
    background-color: transparent;
    color: #868E96;
    border: none;
    border-radius: 3px;
    font-size: 14px;
    font-weight: bold;
    padding: 0px;
    margin: 0px 2px;
}

QPushButton#tabCloseBtn:hover {
    background-color: #CED4DA;
    color: #212529;
}

/* Scrollbars - Horizontal */
QScrollBar:horizontal {
    border: none;
    background-color: #F8F9FA;
    height: 10px;
    margin: 0px;
}

QScrollBar::handle:horizontal {
    background-color: #CED4DA;
    min-width: 30px;
    border-radius: 5px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #ADB5BD;
}

QScrollBar::handle:horizontal:pressed {
    background-color: #868E96;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0px;
    border: none;
    background: none;
}

QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: none;
}
